# Copy this file to .env and fill real values locally.
# Never commit .env.

LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# pipeline/model_client.py reads provider-specific variables.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Cost control and model routing.
AI_KB_DAILY_BUDGET_USD=0.10
AI_KB_ANALYSIS_DEPTH=normal
AI_KB_ANALYSIS_MODEL=deepseek-v4-flash
AI_KB_DEEP_ANALYSIS_MODEL=deepseek-v4-pro

QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
